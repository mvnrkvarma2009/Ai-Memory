/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# ---------------------------------------------------------------
# Environment files
# ---------------------------------------------------------------
# Ignore all local envs...
.env
.env.*
*.env
*.env.local

# ...but ALWAYS keep the example templates checked in.
!.env.example
!**/.env.example

# Credentials / secrets
*token.json*
*credentials.json*
credentials.json
*.key
.credentials
*.pem

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.pytest_cache/
