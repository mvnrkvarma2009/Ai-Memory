# ========= AI Memory — Frontend environment =========
# Copy this file to `.env` inside the `frontend/` folder.
# CRA reads variables prefixed with REACT_APP_ at build time.

# Fully-qualified URL of the FastAPI backend (no trailing slash).
# All API calls are made to `${REACT_APP_BACKEND_URL}/api/...`.
#
# Local dev:    http://localhost:8001
# Production:   https://api.your-domain.com
REACT_APP_BACKEND_URL=http://localhost:8001

# CRA dev-server perf flags (optional — leave commented unless you need them)
# WDS_SOCKET_PORT=443
# DISABLE_ESLINT_PLUGIN=true
