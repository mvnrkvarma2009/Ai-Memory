# ========= AI Memory — Backend environment =========
# Copy this file to `.env` inside the `backend/` folder and fill in real values.
# NEVER commit the real `.env` (already covered by .gitignore).

# --- MongoDB ---
# Local dev example:  mongodb://localhost:27017
# Atlas example:      mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_URL=mongodb://localhost:27017

# The database the backend will read/write.
DB_NAME=ai_memory

# --- CORS ---
# Comma-separated list of allowed origins. Use `*` for local dev only.
CORS_ORIGINS=*

# --- LLM ---
# Universal Emergent LLM key used by the Memory Engine (Claude Sonnet 4.6 by default)
# AND as the fallback for the "Direct AI Connection" handoff feature
# when the user has not brought their own key (BYOK).
#
# Get one from your Emergent dashboard, or replace this integration with a
# direct Anthropic/OpenAI/Gemini key if you fork the LLM layer.
EMERGENT_LLM_KEY=sk-emergent-REPLACE_ME
