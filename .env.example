# ========= AI Memory =========
# Copy this to .env and fill in real values.

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=ai_memory

# CORS (comma-separated origins; use * for local dev)
CORS_ORIGINS=*

# Emergent universal LLM key (Anthropic / OpenAI / Gemini)
# Get one from your Emergent dashboard.
EMERGENT_LLM_KEY=sk-emergent-REPLACE_ME

# Public base URL exposed to the client (used for OAuth redirect)
# In Emergent it's already set; locally use http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
