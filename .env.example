# ========= AI Memory =========
# Copy this file to `.env` and fill in your Google Gemini API key.
# Get one for free at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: pick a specific model. Defaults to gemini-2.5-flash.
# Other choices: gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash
