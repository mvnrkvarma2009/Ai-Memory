{
  "manifest_version": 3,
  "name": "AI Memory — One-Click Capture",
  "version": "1.0.0",
  "description": "Capture your AI conversation and send it straight to AI Memory to build a portable memory package.",
  "permissions": ["scripting", "storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://*.preview.emergentagent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture to AI Memory"
  },
  "content_scripts": [
    {
      "matches": ["https://*.preview.emergentagent.com/*"],
      "js": ["app-inject.js"],
      "run_at": "document_idle"
    }
  ]
}
